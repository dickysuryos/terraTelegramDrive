# ==============================================================================
# ENVIRONMENT CONFIGURATION - TERRA TELEGRAM DRIVE
# ==============================================================================

# Server configuration
PORT=8038
HOST=127.0.0.1
NODE_ENV=production # development / production

# Database configuration (MySQL / MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=database_user
DB_PASSWORD=database_password
DB_NAME=telegram_drive

# Telegram Bot configurations
# 1. Main Bot: Used for uploading files, handling user account links, and web portal access.
TELEGRAM_BOT_TOKEN=your_main_telegram_bot_token_here

# 2. Share Bot: Used specifically for downloading/sharing files via deep-links.
TELEGRAM_SHARE_BOT_TOKEN=your_share_telegram_bot_token_here

# 3. Optional Local Telegram Bot API Server URL.
# Required if you want to upload files larger than 50MB (up to 2GB/4GB) directly via the Web portal.
# If not specified, standard https://api.telegram.org (50MB upload limit for bots) is used.
# TELEGRAM_API_ROOT=http://127.0.0.1:8081

# Security Settings
# Generate a long random string for session encryption (e.g. 32+ characters)
SESSION_SECRET=your_super_secret_session_key_here

# Initial Admin Password (used to bootstrap the default 'admin' user account on first startup)
ADMIN_PASSWORD=adminpass123
